{
  "name": "@creightit-labs/registry",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "bitwhys",
    "url": "https://twitter.com/bitwhys"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:cli": "turbo --filter=creight build",
    "registry:build": "pnpm --filter=web registry:build && pnpm lint:fix && pnpm format:write -- --loglevel silent",
    "registry:capture": "pnpm --filter=www registry:capture",
    "dev": "turbo run dev --parallel",
    "cli:dev": "turbo --filter=creight dev",
    "cli:start": "pnpm --filter=creight start:dev",
    "cli:build": "pnpm --filter=creight build",
    "creight:dev": "turbo --filter=creight dev",
    "creight": "pnpm --filter=creight start:dev",
    "creight:prod": "pnpm --filter=creight start:prod",
    "creight:build": "pnpm --filter=creight build",
    "creight:test": "pnpm --filter=creight test",
    "docs:build": "pnpm --filter=www build:docs",
    "www:dev": "pnpm --filter=www dev",
    "www:build": "pnpm --filter=www build",
    "web:dev": "pnpm --filter=web dev",
    "web:build": "pnpm --filter=web build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "preview": "turbo run preview",
    "typecheck": "turbo run typecheck",
    "format:write": "turbo run format:write",
    "format:check": "turbo run format:check",
    "sync:templates": "./scripts/sync-templates.sh \"templates/*\"",
    "check": "turbo lint typecheck format:check",
    "release": "changeset version",
    "pub:beta": "cd packages/creight && pnpm pub:beta",
    "pub:release": "cd packages/creight && pnpm pub:release",
    "test": "turbo run test --filter=!creight --force"
  },
  "dependencies": {
    "@babel/core": "^7.22.1",
    "@changesets/changelog-github": "^0.4.8",
    "@changesets/cli": "^2.26.1",
    "@commitlint/cli": "^17.6.3",
    "@commitlint/config-conventional": "^17.6.3",
    "@ianvs/prettier-plugin-sort-imports": "^3.7.2",
    "@manypkg/cli": "^0.20.0",
    "@typescript-eslint/parser": "^5.59.7",
    "autoprefixer": "^10.4.14",
    "concurrently": "^8.0.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.41.0",
    "eslint-config-next": "13.3.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-config-turbo": "^1.9.9",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-tailwindcss": "3.13.1",
    "motion": "^12.12.1",
    "postcss": "^8.4.24",
    "prettier": "^2.8.8",
    "pretty-quick": "^3.1.3",
    "puppeteer": "^23.6.0",
    "tailwindcss": "3.4.6",
    "tailwindcss-animate": "^1.0.5",
    "tsx": "^4.1.4",
    "turbo": "^2.5.4",
    "vite": "^5.4.15",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.9"
  },
  "devDependencies": {
    "@types/hast": "^3.0.4",
    "@types/node": "^20.11.27",
    "@types/react": "^18.2.65",
    "@types/react-dom": "^18.2.22",
    "typescript": "^5.5.3"
  },
  "packageManager": "pnpm@10.12.1+sha512.f0dda8580f0ee9481c5c79a1d927b9164f2c478e90992ad268bbb2465a736984391d6333d2c327913578b2804af33474ca554ba29c04a8b13060a717675ae3ac"
}
